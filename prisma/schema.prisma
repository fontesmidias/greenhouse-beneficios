generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Receipt {
  id              String   @id @default(uuid())
  nome            String
  cpf             String
  telefone        String?
  email           String?
  va_valor        Float
  vt_valor        Float
  dias_uteis      Int
  dias_desconto   Int
  observacao      String?

  competencia     String   
  
  status          String   @default("PENDENTE") 
  magicLinkToken  String   @unique @default(uuid())

  createdAt       DateTime @default(now())
  signedAt        DateTime?
  
  pdfOriginalPath String?
  pdfSignedPath   String?
  
  signerIp        String?
  signerUserAgent String?
  signatureHash   String?
}
