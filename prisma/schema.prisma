generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Receipt {
  id              String   @id @default(uuid())
  nome            String
  cpf             String
  telefone        String?
  email           String?
  va_valor        Float
  vt_valor        Float
  dias_uteis      Int
  dias_desconto   Int
  observacao      String?

  competencia     String   
  
  status          String   @default("PENDENTE") 
  magicLinkToken  String   @unique @default(uuid())

  createdAt       DateTime @default(now())
  signedAt        DateTime?
  
  pdfOriginalPath String?
  pdfSignedPath   String?
  
  signerIp        String?
  signerUserAgent String?
  signatureHash   String?
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String   
  cargo     String?
  status    String   @default("PENDENTE") // PENDENTE, ATIVO, RECUSADO
  role      String   @default("USER")     // ADMIN, USER
  
  resetToken       String?  @unique
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
