generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Receipt {
  id              String   @id @default(uuid())
  nome            String
  cpf             String
  telefone        String?
  email           String?
  va_valor        Float
  vt_valor        Float
  dias_uteis      Int
  dias_desconto   Int
  observacao      String?

  competencia     String   
  
  status          String   @default("PENDENTE") 
  magicLinkToken  String   @unique @default(uuid())
  magicLinkPermanent Boolean @default(false)  // F4: Link não expira

  createdAt       DateTime @default(now())
  signedAt        DateTime?
  
  pdfOriginalPath String?
  pdfSignedPath   String?
  
  signerIp        String?
  signerUserAgent String?
  signatureHash   String?

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt]) // F3: Otimizar queries de download em massa
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String   
  cargo     String?
  status    String   @default("PENDENTE") // PENDENTE, ATIVO, RECUSADO
  role      String   @default("USER")     // ADMIN, USER
  
  resetToken       String?  @unique
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SmtpConfig {
  id         String   @id @default(uuid())
  host       String
  port       Int
  user       String
  password   String
  senderName String
  isActive   Boolean  @default(false)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EvoInstance {
  id           String   @id @default(uuid())
  name         String
  apiUrl       String
  apiKey       String
  status       String   @default("PENDENTE") // CONECTADO, PENDENTE, DESCONECTADO
  messageCount Int      @default(0)
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// FEATURE 4: Auditoria de acesso aos magic links
model MagicLinkAudit {
  id        String   @id @default(uuid())
  receiptId String
  userId    String?  // DP que obteve o link
  action    String   // "LINK_OBTAINED", "LINK_COPIED", "LINK_ACCESSED"
  ipAddress String?
  createdAt DateTime @default(now())
  
  @@index([receiptId])
  @@index([action])
  @@index([createdAt])
}
