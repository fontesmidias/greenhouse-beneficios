# =============================================================================
# Greenhouse Benefícios — variáveis de ambiente do stack docker-compose
# =============================================================================
# Copie este arquivo como `.env` (ou cole o conteúdo no campo "Environment
# variables" do Stack no Portainer) e preencha com valores reais.
# NUNCA comite o `.env` — está no .gitignore.
#
# Para gerar segredos fortes:
#   DB_PASSWORD       → openssl rand -base64 32
#   NEXTAUTH_SECRET   → openssl rand -base64 64
# =============================================================================

# Domínio público (sem https://) usado por Traefik e NextAuth
DOMAIN=greenhouse.exemplo.com.br

# Postgres — usado por web, db e db-backup
DB_PASSWORD=

# NextAuth — segredo para assinatura de sessão
NEXTAUTH_SECRET=

# SMTP — bootstrap. Após o primeiro deploy, gerencie via UI (tabela SmtpConfig).
# Estas envs ficam aqui só para o caso de fallback / startup inicial.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Evolution API (WhatsApp) — bootstrap. Após o deploy inicial, gerencie via UI
# (tabela EvoInstance). Mesma lógica do SMTP.
EVO_SERVER_URL=
EVO_GLOBAL_KEY=
EVO_INSTANCE_NAME=

# =============================================================================
# Backup OFFSITE para Backblaze B2 (opcional mas FORTEMENTE recomendado)
# =============================================================================
# Usado pelo service `db-backup-offsite` no docker-compose.yml.
# Sincroniza /backups (volume local) → bucket B2 a cada 1h.
# Setup completo em docs/OFFSITE_BACKUP.md
#
# Se você ainda NÃO tem conta B2: deixe vazio E comente o service
# `db-backup-offsite` no compose, senão o container fica em loop de erro.
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET=greenhouse-backups
